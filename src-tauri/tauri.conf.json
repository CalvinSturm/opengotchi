{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenGotchi",
  "version": "0.1.0",
  "identifier": "com.calvin.opengotchi",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenGotchi",
        "width": 420,
        "height": 720,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
